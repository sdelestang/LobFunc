leeman=leeman
)
poly_list
# Convert each polygon df to an sf polygon and combine into one sf object
closures_sf <- do.call(rbind, lapply(names(poly_list), function(nm) {
df <- poly_list[[nm]]
# Close the polygon ring
coords <- rbind(as.matrix(df[, c("lon", "lat")]),
as.matrix(df[1, c("lon", "lat")]))
st_sf(
area = nm,
geometry = st_sfc(st_polygon(list(coords)), crs = 4326)
)
}))
# Join Time closure periods onto the sf object
closures_sf <- merge(closures_sf, Time, by = "area", all.x = TRUE)
is_closed <- function(lons, lats, year) {
pts <- st_as_sf(data.frame(lon = lons, lat = lats),
coords = c("lon", "lat"), crs = 4326)
# Matrix of which points fall in which closure polygon [n_pts x n_polys]
intersects <- st_intersects(pts, closures_sf, sparse = FALSE)
# For each point, check if ANY matched polygon has an active closure in 'year'
year <- rep_len(year, nrow(pts))
apply(intersects, 1, function(in_poly) {
if (!any(in_poly)) return(FALSE)
matched <- closures_sf[in_poly, ]
any(!is.na(matched$startyr) &
year[which(in_poly)[1]] >= matched$startyr &   # reuse year value
year[which(in_poly)[1]] <= matched$endyr)
})
}
is_closed <- function(lons, lats, year) {
pts <- st_as_sf(data.frame(lon = lons, lat = lats),
coords = c("lon", "lat"), crs = 4326)
year <- rep_len(year, nrow(pts))
intersects <- st_intersects(pts, closures_sf, sparse = FALSE)
mapply(function(in_poly, yr) {
if (!any(in_poly)) return(FALSE)
matched <- closures_sf[in_poly, ]
any(!is.na(matched$startyr) & yr >= matched$startyr & yr <= matched$endyr)
}, asplit(intersects, 1), year)
}
