gammfunc <- function(mod, lev, smooth_avg = TRUE) {
# Check input
if(!inherits(mod, "gamm4")) stop("mod must be a gamm4 object")
# Parametric terms
param_terms <- attr(mod$gam$terms, "term.labels")
if(!lev %in% param_terms) stop("lev must be a parametric term in the model")
other_covs <- setdiff(param_terms, lev)
# Model frame
mf <- mod$gam$model
# Extract smooth variable names (actual columns)
if(length(mod$gam$smooth) > 0) {
smooth_vars <- unlist(lapply(mod$gam$smooth, function(x) x$term))
} else {
smooth_vars <- character(0)
}
# Levels of target factor
lev_levels <- levels(mf[[lev]])
results_list <- vector("list", length(lev_levels))
for(i in seq_along(lev_levels)) {
lv <- lev_levels[i]
sub <- mf[mf[[lev]] == lv, , drop = FALSE]
# Factor and numeric covariates
factor_covs <- other_covs[sapply(sub[other_covs], is.factor)]
numeric_covs <- other_covs[sapply(sub[other_covs], is.numeric)]
# Factor combinations
if(length(factor_covs) > 0) {
factor_grid <- unique(sub[factor_covs])
rownames(factor_grid) <- NULL
} else {
factor_grid <- NULL
}
# Numeric covariates averages
numeric_vals <- as.data.frame(lapply(numeric_covs, function(x) mean(sub[[x]], na.rm = TRUE)))
# Smooth covariates
for(sv in smooth_vars) {
if(smooth_avg) {
numeric_vals[[sv]] <- mean(sub[[sv]], na.rm = TRUE)
} else {
numeric_vals[[sv]] <- mean(mf[[sv]], na.rm = TRUE)
}
}
# Combine into newdat
if(!is.null(factor_grid)) {
newdat <- cbind(data.frame(lv), factor_grid, numeric_vals, stringsAsFactors = FALSE)
} else {
newdat <- cbind(data.frame(lv), numeric_vals, stringsAsFactors = FALSE)
}
names(newdat)[1] <- lev
# Predict including smooths
pred <- predict(mod$gam, newdata = newdat, se.fit = TRUE, exclude = NULL)
# Average over factor combinations if any
fit_link <- mean(pred$fit)
se_link <- sqrt(mean(pred$se.fit^2))
# Back-transform
results_list[[i]] <- data.frame(
lev = lv,
fit_link = fit_link,
se_link = se_link,
lower_link = fit_link - 1.96*se_link,
upper_link = fit_link + 1.96*se_link,
fit = exp(fit_link + 0.5*se_link^2),
lower = exp(fit_link - 1.96*se_link + 0.5*se_link^2),
upper = exp(fit_link + 1.96*se_link + 0.5*se_link^2),
stringsAsFactors = FALSE
)
}
results <- do.call(rbind, results_list)
rownames(results) <- NULL
return(results)
}
library(gamm4)
