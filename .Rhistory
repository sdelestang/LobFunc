library(Tag2STM)
library(LobFunc)
getwd()
setwd(dirname(rstudioapi::getActiveDocumentContext()$path))
obs <- read.csv("M:\\Fisheries Research\\Invertebrates Fisheries\\Rock Lobster\\IBSS\\Analysis\\TagRecaps_forGrowth.csv")
## Chain multiple recaptures
obs <- obs %>% arrange(tag, date) %>% group_by(tag) %>%
mutate(
date = as.Date(date), RLdate = as.Date(RLdate),
RLclength = lag(clength, default = first(RLclength)),
RLdate    = lag(date, default = first(RLdate)),
RLtstep   = lag(tstep, default = first(RLtstep)),
RLlatd    = lag(rclatd, default = first(RLlatd)),
RLlond    = lag(rclond, default = first(RLlond)),
RLarea    = lag(area, default = first(RLarea)),
RLsex     = lag(sex, default = first(RLsex)),
RLyear    = lag(year, default = first(RLyear)),
Ldays     = as.numeric(date - RLdate)
) %>% ungroup() %>% filter(Ldays >= 1)
## WRL natural mortality for plotting to ~ maximum age (years = 3.5/M)
M <- 0.14
## Set up length bins
bins  <- MakeLbin(31, 191, 2)
## Remove missing data, negative liberties
obs %<>% mutate(Lmnth=floor(Ldays/30)) %>% filter(Ldays>0 & floor(clength)%in%40:200 & floor(RLclength)%in%40:200 & !is.na(clength)) %>%  mutate(growth=clength-RLclength)  %>% mutate(year=as.year(RLdate), sex=toupper(sex)) %>% filter(sex%in%c('F','M')) %>%  filter(growth>= -1)
## Remove duplicated data with a small difference in recapture date
obs %<>% mutate(id=paste(tag,RLdate,rclatd,rclond,clength,RLclength)) %>% filter(!duplicated(id)) %>% select(-id)
obs
isclosed
